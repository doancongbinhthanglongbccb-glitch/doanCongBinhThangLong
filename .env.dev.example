# =============================================================================
# Development environment overrides (consumed by docker-compose.dev.yml)
# =============================================================================
# Copy this file to `.env.dev` and fill in real values for your local box.
# `.env.dev` is gitignored. Production deployments use `.env` / docker-compose.prod.yml.
#
# These values used to be hardcoded in `docker-compose.dev.yml`; moving them
# here means dev credentials and JWT secrets stay out of source control while
# still allowing one-command `docker compose -f docker-compose.dev.yml up`.

# --- Initial admin seeding ---------------------------------------------------
ADMIN_USERNAME=admin@example.com
# Use a stronger value locally; backend `assertRuntimeEnv` rejects placeholders.
ADMIN_PASSWORD=ChangeMe!Dev@1234

# --- JWT secrets (must be long random strings, not the placeholders below) ---
JWT_SECRET=change-me-dev-access-secret-change-me-dev
JWT_REFRESH_SECRET=change-me-dev-refresh-secret-change-me-dev

# --- Token lifetimes ---------------------------------------------------------
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d

# --- Cookie / CORS / runtime -------------------------------------------------
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
CORS_ORIGIN=http://localhost:3000
REQUEST_BODY_LIMIT=10mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
LOG_LEVEL=info
SWAGGER_ENABLED=true

# --- Mongo (defaults to the in-cluster service) ------------------------------
MONGO_URI=mongodb://mongo:27017/doan_cms

# --- Compose host port mappings ----------------------------------------------
DEV_API_PORT=8000
DEV_HTTP_PORT=3000
