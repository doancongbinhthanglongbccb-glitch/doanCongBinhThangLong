## Production environment (for docker-compose.prod.yml)
## Copy to `.env.prod` on the VPS (DO NOT COMMIT `.env.prod`)

# --- Domain / Let's Encrypt ---------------------------------------------------
LETSENCRYPT_DOMAIN=example.com
LETSENCRYPT_EMAIL=admin@example.com

# --- Frontend (build-time) ----------------------------------------------------
VITE_GOOGLE_CLIENT_ID=

# --- Mongo -------------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=replace_with_strong_password

# --- Initial admin seeding ----------------------------------------------------
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=replace_with_strong_password

# --- Auth secrets -------------------------------------------------------------
JWT_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret

# --- Cookies / CORS -----------------------------------------------------------
# Backend enforces COOKIE_SECURE=true in production.
COOKIE_DOMAIN=example.com
COOKIE_SAME_SITE=lax
## IMPORTANT: must match your public origin(s)
CORS_ORIGIN=https://example.com

# --- Google Login (backend) ---------------------------------------------------
GOOGLE_CLIENT_ID=
# Choose ONE strategy below (recommended: allowlist emails for admin panel)
GOOGLE_ALLOWED_EMAILS=admin@example.com,editor@example.com
GOOGLE_ALLOWED_DOMAIN=

# --- Runtime -----------------------------------------------------------------
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d
REQUEST_BODY_LIMIT=10mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
LOG_LEVEL=info
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Backups -----------------------------------------------------------------
BACKUP_INTERVAL_SECONDS=43200

