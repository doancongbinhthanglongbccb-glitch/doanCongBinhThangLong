NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://<mongo_user>:<mongo_password>@localhost:27017/doan_cms?authSource=admin
JWT_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
CORS_ORIGIN=http://localhost:8081,http://localhost:5173
REQUEST_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
LOG_LEVEL=info
SWAGGER_ENABLED=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Credentials for seeding admin user
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=replace_with_strong_password
